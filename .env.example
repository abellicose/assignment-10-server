PORT=5000

# Paste your full MongoDB Atlas connection string here (recommended):
# Atlas: Connect -> Drivers -> copy the mongodb+srv://... string, set the password.
DB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# --- OR, instead of DB_URI, provide the parts and let the server build it ---
# DB_USER=your_db_user
# DB_PASS=your_db_password
# DB_CLUSTER=cluster0.xxxxx.mongodb.net

ACCESS_TOKEN_SECRET=your_jwt_secret
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
CLIENT_URL=http://localhost:3000
